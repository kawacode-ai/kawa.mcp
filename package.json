{
  "name": "@kawacode/mcp",
  "version": "5.3.0",
  "description": "Team-aware memory for Claude Code, Cursor, and other AI coding assistants — intent tracking, decision history, real-time team conflict detection.",
  "main": "build/index.js",
  "bin": {
    "kawacode-mcp": "build/index.js",
    "kawacode-capture-thoughts": "build/capture-thoughts.js",
    "kawacode-extract-trigger": "build/extract-trigger.js",
    "kawacode-pre-edit-decision-check": "build/pre-edit-decision-check-hook.js"
  },
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "files": [
    "build",
    "LICENSE",
    "README.md",
    "CLAUDE.md.example"
  ],
  "mcpName": "ai.kawacode/mcp",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "clean": "rm -rf build",
    "test": "yarn build && node --test 'build/pre_edit_check/*.test.js'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
